# 第三方API环境变量配置示例
# 复制此文件为 .env 并填写实际的API密钥

# ============================================
# 天眼查 API 配置
# ============================================
# 申请地址: https://open.tianyancha.com/
TIANYANCHA_API_KEY=your_tianyancha_api_key_here
TIANYANCHA_API_SECRET=your_tianyancha_api_secret_here

# ============================================
# 高德地图 API 配置
# ============================================
# 申请地址: https://lbs.amap.com/
AMAP_KEY=your_amap_key_here
AMAP_SECURITY_CONFIG=your_amap_security_config_here

# ============================================
# 阿里云短信服务配置
# ============================================
# 申请地址: https://www.aliyun.com/product/sms
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_VERIFY_CODE_TEMPLATE_CODE=SMS_xxxxxxxxx
ALIYUN_NOTIFICATION_TEMPLATE_CODE=SMS_xxxxxxxxx

# ============================================
# 腾讯云短信服务配置（可选）
# ============================================
# 申请地址: https://cloud.tencent.com/product/sms
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_SMS_APP_ID=your_tencent_sms_app_id
TENCENT_SMS_SIGN_NAME=your_tencent_sign_name
TENCENT_VERIFY_CODE_TEMPLATE_ID=your_template_id
TENCENT_NOTIFICATION_TEMPLATE_ID=your_template_id
